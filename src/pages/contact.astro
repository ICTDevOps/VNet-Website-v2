---
import PageShell from "../layouts/PageShell.astro";
import PageHero from "../components/PageHero.astro";
import PageSection from "../components/PageSection.astro";

const faqs = [
  {
    q: "Comment démarre une mission type ?",
    a: "Un premier appel de 30 minutes pour comprendre votre contexte. Sous 48 h, on revient avec un cadrage écrit (objectifs, périmètre, livrables, planning, coûts) et au moins deux options. Pas d'engagement à cette étape — c'est gratuit et c'est le format qui nous évite des projets mal cadrés.",
  },
  {
    q: "Travaillez-vous avec les PME ou uniquement les grands comptes ?",
    a: "Les deux. La majorité de nos clients sont des PME de 30 à 300 personnes, mais on intervient aussi sur des projets plus larges en mode expert. Le ticket d'entrée minimum n'est pas une question de taille d'entreprise, c'est une question de sens du projet.",
  },
  {
    q: "Quels sont vos délais d'intervention ?",
    a: "Pour un cadrage : sous 48 h après un premier échange. Pour le démarrage d'une mission : généralement 2 à 4 semaines, selon notre charge et la complexité. Pour les urgences réelles (incident en production sur un périmètre que l'on connaît), on essaie de débloquer dans la journée.",
  },
  {
    q: "Vos livrables restent-ils chez nous à la fin de la mission ?",
    a: "Toujours. L'IaC va dans votre dépôt Git, les runbooks dans votre wiki, les comptes administratifs sont à vous. Si nous quittons la mission demain, vous avez tout pour continuer — c'est même un des critères de qualité d'une mission réussie chez nous.",
  },
  {
    q: "Proposez-vous du support / MCO après la mise en production ?",
    a: "Oui, en option, avec engagement de transparence : on documente ce que l'on fait, on transfère régulièrement les compétences, et le contrat est résiliable avec un préavis raisonnable. Pas d'enfermement contractuel.",
  },
  {
    q: "Vous formez aussi nos équipes ?",
    a: "Oui, sur les domaines couverts (Azure, Terraform, M365, Entra, IA). Les formations sont décrites sur la page Formations. Pour les petites équipes, on bricole souvent un format hybride : un peu d'atelier, un peu de pair-coding sur des cas réels.",
  },
];
---

<PageShell
  title="Contact — VNET Consult"
  description="Contactez VNET Consult pour un audit, un cadrage ou un projet d'infrastructure cloud Azure, Microsoft 365 ou IA. Belgique &amp; Luxembourg."
  current="contact"
>
  <PageHero
    eyebrow="// contact"
    title={'<span class="grad-text">Démarrer</span> une discussion.'}
    subtitle="Le format qui marche le mieux : un appel de 30 minutes pour décrire votre contexte. Sous 48 h, on revient avec un cadrage écrit (périmètre, options, chiffrage) sans engagement."
  />

  <PageSection eyebrow="// canaux">
    <div class="channels-grid">
      <a class="channel-card primary" href="mailto:contact@vnetconsult.be?subject=Demande%20de%20rendez-vous%20%E2%80%94%20VNET%20Consult">
        <div class="channel-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" />
          </svg>
        </div>
        <div class="channel-label">Email</div>
        <div class="channel-value">contact@vnetconsult.be</div>
        <div class="channel-hint">Réponse sous 24 h ouvrées</div>
      </a>

      <a class="channel-card" href="tel:+32473332474">
        <div class="channel-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A18 18 0 0 1 3 6a2 2 0 0 1 2-2z" />
          </svg>
        </div>
        <div class="channel-label">Téléphone</div>
        <div class="channel-value">+32 473 33 24 74</div>
        <div class="channel-hint">Lun–ven · 9 h–18 h</div>
      </a>

      <a class="channel-card" href="https://www.linkedin.com/company/vnetconsult" target="_blank" rel="noopener">
        <div class="channel-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5C0 2.12 1.11 1 2.5 1S4.98 2.12 4.98 3.5zM.22 8h4.56v14H.22zM8 8h4.36v1.92h.06c.61-1.15 2.1-2.37 4.32-2.37 4.62 0 5.47 3.04 5.47 7v9.45h-4.56v-8.38c0-2-.04-4.57-2.78-4.57-2.78 0-3.21 2.17-3.21 4.42V22H8z" />
          </svg>
        </div>
        <div class="channel-label">LinkedIn</div>
        <div class="channel-value">linkedin.com/company/vnetconsult</div>
        <div class="channel-hint">Veille technique &amp; actualités</div>
      </a>
    </div>

    <div class="address-block">
      <div class="address-label">// adresse</div>
      <div class="address-value">
        VNET Consult<br />
        Rue Hecq 51<br />
        7160 Chapelle-Lez-Herlaimont<br />
        Belgique
      </div>
      <div class="address-area">Zone d'intervention : Belgique &amp; Luxembourg — distanciel partout en Europe</div>
    </div>
  </PageSection>

  <PageSection
    eyebrow="// faq"
    title="Questions fréquentes"
    subtitle="Si votre question n'est pas listée, le mail ou le téléphone restent les meilleurs canaux — on répond toujours."
  >
    <div class="faq-list">
      {
        faqs.map((f) => (
          <details class="faq-item">
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">{f.a}</div>
          </details>
        ))
      }
    </div>
  </PageSection>
</PageShell>

<style>
  .channels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-bottom: 48px;
  }
  .channel-card {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 28px;
    color: var(--fg);
    text-decoration: none;
    transition:
      transform 0.2s,
      border-color 0.2s,
      background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .channel-card:hover {
    transform: translateY(-2px);
    border-color: rgba(76, 201, 240, 0.3);
    background: var(--bg-3);
  }
  .channel-card.primary {
    background: linear-gradient(
      135deg,
      rgba(76, 201, 240, 0.06),
      rgba(139, 92, 246, 0.06)
    );
    border-color: rgba(76, 201, 240, 0.25);
  }
  .channel-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(76, 201, 240, 0.1);
    color: var(--cyan);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    border: 1px solid rgba(76, 201, 240, 0.2);
  }
  .channel-icon svg {
    width: 20px;
    height: 20px;
  }
  .channel-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .channel-value {
    font-size: 17px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    word-break: break-word;
  }
  .channel-hint {
    font-size: 13px;
    color: var(--fg-dim);
  }

  .address-block {
    border-top: 1px solid var(--line);
    padding-top: 32px;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: start;
    gap: 32px;
  }
  .address-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding-top: 4px;
  }
  .address-value {
    font-size: 15px;
    color: var(--fg);
    line-height: 1.7;
  }
  .address-area {
    font-size: 13px;
    color: var(--fg-dim);
    font-style: italic;
    border-left: 1px solid var(--line);
    padding-left: 24px;
    line-height: 1.6;
  }

  .faq-list {
    display: grid;
    gap: 12px;
    max-width: 880px;
  }
  .faq-item {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
  }
  .faq-item[open] {
    border-color: rgba(76, 201, 240, 0.3);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    font-weight: 500;
    color: var(--fg);
    font-size: 16px;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-icon {
    font-family: "JetBrains Mono", monospace;
    color: var(--cyan);
    font-size: 18px;
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-a {
    padding: 0 24px 22px;
    color: var(--fg-dim);
    font-size: 15px;
    line-height: 1.7;
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  @media (max-width: 900px) {
    .channels-grid {
      grid-template-columns: 1fr;
    }
    .address-block {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .address-area {
      border-left: none;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: 16px;
    }
  }
</style>
