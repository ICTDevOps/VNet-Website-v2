---
const { current } = Astro.props as { current?: string };
const isHome = Astro.url.pathname === "/";

type Service = { href: string; label: string; key: string };
const services: Service[] = [
  { href: "/services/cloud-azure", label: "Cloud Azure", key: "cloud-azure" },
  { href: "/services/microsoft-365", label: "Microsoft 365", key: "microsoft-365" },
  { href: "/services/intelligence-artificielle", label: "IA & Copilot", key: "ia" },
  { href: "/services/formations", label: "Formations", key: "formations" },
];

const links = [
  { href: isHome ? "#plateformes" : "/#plateformes", label: "Plateformes", key: "plateformes", services },
  { href: isHome ? "#approche" : "/#approche", label: "Approche", key: "approche" },
  { href: "/a-propos", label: "À propos", key: "a-propos" },
];

const isServiceCurrent = services.some((s) => s.key === current);
---

<nav>
  <a class="logo" href="/">
    <span class="logo-mark">
      <svg viewBox="0 0 30 30" fill="none">
        <defs>
          <linearGradient id="lg1" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#4cc9f0"></stop>
            <stop offset="100%" stop-color="#8b5cf6"></stop>
          </linearGradient>
        </defs>
        <circle cx="15" cy="6" r="2.5" fill="url(#lg1)"></circle>
        <circle cx="6" cy="22" r="2.5" fill="url(#lg1)"></circle>
        <circle cx="24" cy="22" r="2.5" fill="url(#lg1)"></circle>
        <line
          x1="15"
          y1="6"
          x2="6"
          y2="22"
          stroke="url(#lg1)"
          stroke-width="1.2"
          opacity="0.7"></line>
        <line
          x1="15"
          y1="6"
          x2="24"
          y2="22"
          stroke="url(#lg1)"
          stroke-width="1.2"
          opacity="0.7"></line>
        <line
          x1="6"
          y1="22"
          x2="24"
          y2="22"
          stroke="url(#lg1)"
          stroke-width="1.2"
          opacity="0.7"></line>
      </svg>
    </span>
    <span class="logo-text">vnet<span>.</span>consult</span>
  </a>
  <ul>
    {links.map((l) => (
      <li class={l.services ? "has-menu" : ""}>
        <a
          href={l.href}
          class={(current === l.key || (l.services && isServiceCurrent)) ? "active" : ""}
        >
          {l.label}
          {l.services && <span class="menu-caret">↓</span>}
        </a>
        {l.services && (
          <div class="submenu">
            {l.services.map((s) => (
              <a
                href={s.href}
                class={current === s.key ? "sub-active" : ""}
              >
                {s.label}
              </a>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>
  <div class="nav-right">
    <span class="lang"><span class="active">FR</span> · EN</span>
    <a href="/contact" class="nav-cta">Démarrer un projet →</a>
  </div>
</nav>

<style>
  nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 48px;
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(14px);
    background: rgba(7, 9, 15, 0.75);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: "JetBrains Mono", monospace;
    font-weight: 500;
    font-size: 15px;
    color: var(--fg);
    text-decoration: none;
  }
  .logo-mark {
    width: 30px;
    height: 30px;
    display: inline-block;
  }
  .logo-mark svg {
    width: 100%;
    height: 100%;
  }
  .logo-text span {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  nav ul {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  nav li {
    position: relative;
  }
  .menu-caret {
    font-size: 9px;
    color: var(--fg-faint);
    margin-left: 4px;
    display: inline-block;
    transform: translateY(-1px);
  }
  .submenu {
    position: absolute;
    top: 100%;
    left: -16px;
    margin-top: 14px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 8px;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.18s, transform 0.18s, visibility 0.18s;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    z-index: 12;
  }
  nav li.has-menu:hover .submenu,
  nav li.has-menu:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .submenu a {
    display: block;
    padding: 10px 14px;
    border-radius: 8px;
    color: var(--fg-dim);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .submenu a:hover {
    background: var(--bg-3);
    color: var(--fg);
  }
  .submenu a.sub-active {
    color: var(--cyan);
    background: rgba(76, 201, 240, 0.06);
  }
  nav a {
    color: var(--fg-dim);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }
  nav a:hover {
    color: var(--fg);
  }
  nav a.active {
    color: var(--fg);
  }
  nav a.active::after {
    content: "";
    display: block;
    margin-top: 4px;
    height: 1px;
    background: var(--grad);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .lang {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--fg-faint);
    letter-spacing: 0.05em;
  }
  .lang .active {
    color: var(--fg);
    font-weight: 500;
  }
  .nav-cta {
    padding: 10px 18px;
    background: var(--fg);
    color: var(--bg);
    border-radius: 6px;
    font-weight: 600;
    font-size: 13px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .nav-cta:hover {
    opacity: 0.88;
  }

  @media (max-width: 900px) {
    nav {
      padding: 20px 24px;
    }
    nav ul {
      display: none;
    }
  }
</style>
