---

<section class="about">
  <div class="about-content">
    <div class="section-eyebrow">// À propos</div>
    <p class="quote">
      « Quinze ans d'infrastructure m'ont appris une chose : la
      <span class="grad-text">complexité</span> n'est jamais un objectif. C'est
      un constat d'échec. »
    </p>
    <div class="signature">
      <div class="sig-avatar">OM</div>
      <div class="sig-text">
        <strong>Olivier Malfroidt</strong>Fondateur · Architecte cloud Azure
      </div>
    </div>
    <a href="#" class="about-link">Lire le manifeste complet →</a>
  </div>
  <div class="about-visual">
    <canvas id="about-canvas"></canvas>
  </div>
</section>

<script>
  import { mountAboutNetwork } from "../scripts/about-network";

  const c = document.getElementById("about-canvas");
  if (c instanceof HTMLCanvasElement) {
    mountAboutNetwork(c);
  }
</script>

<style>
  .about {
    position: relative;
    z-index: 5;
    max-width: 1280px;
    margin: 160px auto 0;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .section-eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    font-weight: 500;
  }
  .about-content .quote {
    font-size: 30px;
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }
  .signature {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }
  .sig-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--grad);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--bg);
    font-size: 15px;
  }
  .sig-text {
    font-size: 14px;
    color: var(--fg-dim);
  }
  .sig-text strong {
    color: var(--fg);
    font-weight: 600;
    display: block;
  }
  .about-link {
    color: var(--cyan);
    font-weight: 500;
    text-decoration: none;
    font-size: 15px;
    border-bottom: 1px solid var(--cyan);
    padding-bottom: 2px;
  }
  .about-visual {
    aspect-ratio: 1;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
  }
  .about-visual canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .about {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 0 24px;
    }
  }
</style>
