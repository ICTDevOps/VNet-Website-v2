---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  pill?: string;
}

const { eyebrow, title, subtitle, pill } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="page-hero-eyebrow">{eyebrow}</div>
    {pill && <span class="page-hero-pill">{pill}</span>}
    <h1 set:html={title}></h1>
    {subtitle && <p class="lede">{subtitle}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    z-index: 5;
    padding: 80px 48px 64px;
    max-width: 1280px;
    margin: 0 auto;
    border-bottom: 1px solid var(--line);
  }
  .page-hero-inner {
    max-width: 880px;
  }
  .page-hero-eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 18px;
    font-weight: 500;
  }
  .page-hero-pill {
    display: inline-block;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 100px;
    background: rgba(76, 201, 240, 0.1);
    color: var(--cyan);
    border: 1px solid rgba(76, 201, 240, 0.2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 22px;
  }
  .page-hero h1 {
    font-size: clamp(38px, 5.5vw, 68px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin-bottom: 22px;
  }
  .page-hero .lede {
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg-dim);
    max-width: 680px;
  }

  @media (max-width: 900px) {
    .page-hero {
      padding: 56px 24px 48px;
    }
  }
</style>
