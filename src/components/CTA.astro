<section class="cta-section" id="contact">
  <h2>Prêt à connecter <span class="grad-text">le tout</span> ?</h2>
  <p>
    Un appel de 30 minutes pour décrire votre contexte. Nous revenons avec un
    cadrage écrit sous 48 h, sans engagement.
  </p>
  <a href="#" class="btn-primary">Réserver un créneau →</a>
</section>

<style>
  .cta-section {
    position: relative;
    z-index: 5;
    max-width: 1280px;
    margin: 160px auto 80px;
    padding: 80px 48px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 20px;
    text-align: center;
    overflow: hidden;
  }
  .cta-section::before {
    content: "";
    position: absolute;
    inset: -100px;
    background:
      radial-gradient(
        circle at 30% 50%,
        var(--cyan-glow) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 70% 50%,
        var(--violet-glow) 0%,
        transparent 50%
      );
    z-index: 0;
    opacity: 0.6;
  }
  .cta-section > * {
    position: relative;
    z-index: 1;
  }
  .cta-section h2 {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .cta-section p {
    color: var(--fg-dim);
    margin-bottom: 36px;
    font-size: 17px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }
  .btn-primary {
    padding: 15px 28px;
    background: var(--fg);
    color: var(--bg);
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition:
      transform 0.15s,
      box-shadow 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 40px var(--cyan-glow);
  }

  @media (max-width: 900px) {
    .cta-section {
      margin-left: 24px;
      margin-right: 24px;
      padding: 48px 24px;
    }
  }
</style>
