---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "VNET Consult — Architecture cloud Azure, M365 & IA pour PME",
  description = "Architecture Azure, migrations Microsoft 365 et intégration IA pour PME et grandes organisations en Belgique et Luxembourg. Pas de discours commercial — juste de l'ingénierie qui tient en production.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
